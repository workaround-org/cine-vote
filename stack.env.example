# cine-vote — Portainer stack environment (TEMPLATE).
# Copy to stack.env and fill in real values: cp stack.env.example stack.env
# stack.env is gitignored so real secrets are never committed.
# Portainer reads stack.env for ${VAR} substitution in the compose.
# For local use: docker compose --env-file stack.env up -d

DB_NAME=cinevote
DB_USER=cinevote
DB_PASSWORD=change-me-strong-db-password

# OMDb movie API key — free at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your-omdb-key

# Admin login (bootstrapped on first start if no admin user exists).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Form-auth session cookie encryption key — MUST be at least 32 characters.
SESSION_ENCRYPTION_KEY=change-me-to-a-random-32+-character-secret
